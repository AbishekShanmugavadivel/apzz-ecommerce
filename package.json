{
  "name": "apzzz-ecommerce",
  "version": "1.0.0",
  "description": "Apzzz - Full-stack ecommerce application",
  "scripts": {
    "start": "concurrently \"npm run backend\" \"npm run frontend\"",
    "backend": "cd backend && npm start",
    "frontend": "cd frontend && npm start",
    "install-all": "npm install && cd backend && npm install && cd ../frontend && npm install",
    "seed": "cd backend && node seedProducts.js && node seedAdmin.js"
  },
  "devDependencies": {
    "concurrently": "^7.6.0"
  },
  "dependencies": {
    "cors": "^2.8.6"
  }
}
